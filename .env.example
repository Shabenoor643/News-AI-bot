# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Gmail SMTP — use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
APPROVER_EMAILS=approver@example.com

# Approval secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
APPROVAL_SECRET=change_me_to_a_long_random_secret

# App config
PORT=3001
BASE_URL=http://localhost:3001
SITE_NAME=NewsAI

# Pipeline config
CRAWL_INTERVAL_HOURS=6
RELEVANCE_THRESHOLD=0.6
MAX_RETRIES=2

# Image search
USE_GEMINI_IMAGE_SEARCH=1
SERPAPI_API_KEY=your_serpapi_key
IMAGE_OVERLAY_TEXT=1

# Observability
MLFLOW_ENABLED=1
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=newsai-blogs
EXCEL_LOG_PATH=./logs.xlsx

# CMS (optional webhook endpoint to POST published articles)
CMS_WEBHOOK_URL=https://your-cms.com/api/articles
CMS_API_KEY=your_cms_key

# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/newsbot
